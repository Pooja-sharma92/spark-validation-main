# Docker Compose Environment Configuration
# Copy this file to .env and modify as needed

# ═══════════════════════════════════════════════════════════════
# Data Directory
# ═══════════════════════════════════════════════════════════════
# All persistent data will be stored in this directory.
# Default: ./data (relative to docker-compose.yml location)
#
# Structure:
#   ${DATA_DIR}/
#   ├── gitea/          # Gitea repository data
#   ├── gitea-runner/   # CI runner data
#   ├── spark/
#   │   ├── jobs/       # Spark job files
#   │   ├── logs/       # Spark execution logs
#   │   └── jars/       # Additional JARs
#   ├── jupyter/
#   │   └── notebooks/  # Jupyter notebooks
#   ├── minio/          # S3-compatible object storage
#   ├── iceberg/
#   │   ├── catalog/    # Iceberg catalog metadata
#   │   └── jars/       # Iceberg JARs
#   ├── redis/          # Redis persistence
#   └── postgres/       # PostgreSQL data
#
# Examples:
#   DATA_DIR=./data                    # Default (local to docker dir)
#   DATA_DIR=/var/lib/spark-validator  # Absolute path
#   DATA_DIR=~/docker-data/validator   # Home directory

DATA_DIR=./data

# ═══════════════════════════════════════════════════════════════
# Git Webhook Secret (for validation-gateway)
# ═══════════════════════════════════════════════════════════════
# GIT_WEBHOOK_SECRET=your-secret-here
