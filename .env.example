# Spark Code Analyzer - Environment Configuration
# Copy this file to .env and fill in your actual values

# ============================================
# AI Provider Configuration
# ============================================

# Option 1: OpenAI (GPT-4)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-openai-api-key-here

# Option 2: Azure OpenAI
# Get from Azure Portal: https://portal.azure.com/
AZURE_OPENAI_ENDPOINT=https://your-resource-name.openai.azure.com/
AZURE_OPENAI_KEY=your-azure-openai-key-here
AZURE_OPENAI_DEPLOYMENT=gpt-4
AZURE_OPENAI_API_VERSION=2024-02-15-preview

# Option 3: Anthropic Claude
# Get your key from: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key-here

# Option 4: Local Ollama (no key needed)
# Install: https://ollama.ai/
# OLLAMA_BASE_URL=http://localhost:11434

# ============================================
# Analysis Configuration
# ============================================

# Enable/disable AI analysis (true/false)
ENABLE_AI_ANALYSIS=false

# AI provider to use (openai, azure-openai, anthropic, ollama)
AI_PROVIDER=openai

# Model to use (or deployment name for Azure)
AI_MODEL=gpt-4

# ============================================
# Report Configuration
# ============================================

# Output format (markdown, html, json)
REPORT_FORMAT=markdown

# Output directory
REPORT_OUTPUT_PATH=./analysis_reports

# ============================================
# Analysis Thresholds
# ============================================

# Maximum allowed critical issues
MAX_CRITICAL_ISSUES=0

# Maximum allowed warning issues
MAX_WARNING_ISSUES=10

# Cyclomatic complexity threshold
MAX_COMPLEXITY=15

# Maximum function lines
MAX_FUNCTION_LINES=100
