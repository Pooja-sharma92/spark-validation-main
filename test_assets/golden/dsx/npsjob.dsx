ws in the database\" label=\"Update statement\" maxOccurs=\"1\" minOccurs=\"1\" multiline=\"true\" name=\"UpdateStatement\" required=\"true\" sqlBuilderDescription=\"Select a SQL statement tool\" sqlBuilderLabel=\"Tools\" statementType=\"UPDATE\" type=\"string\" xsi:type=\"asc:SQLBuilderProperty\"><Filter logic=\"and\"><FilterProperty logic=\"or\" property=\"/Usage/GenerateSQL\">false</FilterProperty><FilterProperty logic=\"or\" property=\"/Usage/WriteMode\">1 3 4</FilterProperty></Filter><Callouts><Callout callout=\"generateSQL\" calloutLabel=\"Generate SQL statement\" calloutType=\"builder\"><CalloutArgument name=\"statementType\">UpdateStatementSQL</CalloutArgument></Callout><Callout callout=\"validateSQL\" calloutLabel=\"Validate SQL statement\" calloutType=\"validator\"/></Callouts><Property description=\"Statement to be executed when updating rows in the database\" hidden=\"true\" label=\"Update statement\" maxOccurs=\"1\" minOccurs=\"0\" name=\"Tables\" required=\"false\" type=\"category\"><Property description=\"Statement to be executed when updating rows in the database\" label=\"Update statement\" maxOccurs=\"unbounded\" minOccurs=\"0\" name=\"Table\" required=\"false\" type=\"string\"/></Property><Property description=\"List of statement parameters\" hidden=\"true\" label=\"Parameter list\" maxOccurs=\"1\" minOccurs=\"0\" name=\"Parameters\" required=\"false\" type=\"category\"><Property description=\"Statement parameter represented as a comma delimited triplet containing ORCHESTRATE variable name, corresponding field name, and table name\" label=\"Parameter\" maxOccurs=\"unbounded\" minOccurs=\"0\" name=\"Parameter\" required=\"false\" type=\"string\"/></Property><Property description=\"Statement to be executed when updating rows in the database\" hidden=\"true\" label=\"Update statement\" maxOccurs=\"1\" minOccurs=\"0\" name=\"WhereClause\" required=\"false\" type=\"string\"/></Property><Property contexts=\"target\" description=\"Statement to be executed when deleting rows from the database\" label=\"Delete statement\" maxOccurs=\"1\" minOccurs=\"1\" multiline=\"true\" name=\"DeleteStatement\" required=\"true\" sqlBuilderDescription=\"Select a SQL statement tool\" sqlBuilderLabel=\"Tools\" statementType=\"DELETE\" type=\"string\" xsi:type=\"asc:SQLBuilderProperty\"><Filter logic=\"and\"><FilterProperty logic=\"or\" property=\"/Usage/GenerateSQL\">false</FilterProperty><FilterProperty logic=\"or\" property=\"/Usage/WriteMode\">2 5</FilterProperty></Filter><Callouts><Callout callout=\"generateSQL\" calloutLabel=\"Generate SQL statement\" calloutType=\"builder\"><CalloutArgument name=\"statementType\">DeleteStatementSQL</CalloutArgument></Callout><Callout callout=\"validateSQL\" calloutLabel=\"Validate SQL statement\" calloutType=\"validator\"/></Callouts><Property description=\"Statement to be executed when deleting rows from the database\" hidden=\"true\" label=\"Delete statement\" maxOccurs=\"1\" minOccurs=\"0\" name=\"Tables\" required=\"false\" type=\"category\"><Property description=\"Statement to be executed when deleting rows from the database\" label=\"Delete statement\" maxOccurs=\"unbounded\" minOccurs=\"0\" name=\"Table\" required=\"false\" type=\"string\"/></Property><Property description=\"List of statement parameters\" hidden=\"true\" label=\"Parameter list\" maxOccurs=\"1\" minOccurs=\"0\" name=\"Parameters\" required=\"false\" type=\"category\"><Property description=\"Statement parameter represented as a comma delimited triplet containing ORCHESTRATE variable name, corresponding field name, and table name\" label=\"Parameter\" maxOccurs=\"unbounded\" minOccurs=\"0\" name=\"Parameter\" required=\"false\" type=\"string\"/></Property><Property description=\"Statement to be executed when deleting rows from the database\" hidden=\"true\" label=\"Delete statement\" maxOccurs=\"1\" minOccurs=\"0\" name=\"WhereClause\" required=\"false\" type=\"string\"/></Property><Property contexts=\"target\" default=\"1\" description=\"Source of the user-defined SQL statements\" filterProperty=\"/Usage/WriteMode\" filterValue=\"7\" label=\"User-defined SQL\" maxOccurs=\"1\" minOccurs=\"1\" name=\"UserDefinedSQL\" required=\"true\" type=\"int\"><Value code=\"1\">Statements</Value><Value code=\"2\">File</Value><Property description=\"SQL statements to be executed for each input row\" filterProperty=\"/Usage/SQL/UserDefinedSQL\" filterValue=\"1\" label=\"Statements\" maxOccurs=\"1\" minOccurs=\"1\" multiline=\"true\" name=\"Statements\" required=\"true\" type=\"string\"/><Property description=\"File on the conductor node that contains SQL statements to be executed for each input row\" filterProperty=\"/Usage/SQL/UserDefinedSQL\" filterValue=\"2\" label=\"File\" maxLength=\"256\" maxOccurs=\"1\" minLength=\"1\" minOccurs=\"1\" name=\"File\" required=\"true\" type=\"string\"><Property description=\"IANA character set name\" label=\"Character set\" maxLength=\"256\" maxOccurs=\"1\" minLength=\"1\" minOccurs=\"0\" name=\"CharacterSet\" required=\"false\" type=\"string\"/></Property><Property default=\"true\" description=\"Abort the statement sequence when an error occurs\" label=\"Fail on error\" maxOccurs=\"1\" minOccurs=\"0\" name=\"FailOnError\" required=\"false\" type=\"bool\"/><Property default=\"false\" description=\"Do not abort the job when a DB2 Warning is encountered, report as an information messsage.\" label=\"Treat warnings as info\" maxOccurs=\"1\" minOccurs=\"0\" name=\"SuppressWarnings\" required=\"false\" type=\"bool\"/></Property><Property contexts=\"source\" default=\"false\" description=\"Enable or disable partitioned reads by using the selected partitioning method.\" engines=\"ee\" filterChildPropertiesOnValue=\"true\" label=\"Enable partitioned reads\" name=\"EnablePartitioning\" required=\"false\" type=\"bool\"><Property contexts=\"source\" default=\"1\" description=\"The method to use for partitioned reads.\" label=\"Partitioned reads method\" name=\"PartitioningMethod\" required=\"false\" type=\"int\"><Value code=\"0\" filterProperty=\"/Connection/UseDirectConnections\" filterValue=\"0\">Modulus</Value><Value code=\"1\" filterProperty=\"/Connection/UseDirectConnections\" filterValue=\"0\">Minimum and maximum range</Value><Value code=\"2\">DB2 connector</Value><Property description=\"Specifies the table that is used by the selected partitioned reads method.\" filterProperty=\"/Usage/SQL/EnablePartitioning/PartitioningMethod\" filterValue=\"1 2\" label=\"Table name\" name=\"TableName\" required=\"true\" type=\"string\"/><Property description=\"Specifies the key column that is used by the selected partitioned reads method. This column must be a numeric data type.\" filterProperty=\"/Usage/SQL/EnablePartitioning/PartitioningMethod\" filterValue=\"0 1\" label=\"Column name\" maxLength=\"256\" minLength=\"1\" name=\"KeyField\" required=\"true\" type=\"string\"/><Property default=\"true\" description=\"Specifies whether the connector should modify the SELECT statement at run-time and generate the required partitioning clause\" label=\"Generate partitioning SQL\" maxOccurs=\"1\" minOccurs=\"0\" name=\"GenPartitioningSQL\" required=\"false\" type=\"bool\"><Filter logic=\"and\"><FilterProperty logic=\"or\" property=\"/Usage/SQL/EnablePartitioning/PartitioningMethod\">2</FilterProperty><FilterProperty logic=\"or\" property=\"/Usage/GenerateSQL\">false</FilterProperty></Filter></Property></Property></Property></Property><Property contexts=\"target\" default=\"0\" description=\"Select the action to perform on the database table\" label=\"Table action\" maxOccurs=\"1\" minOccurs=\"0\" name=\"TableAction\" required=\"true\" type=\"int\"><Value code=\"0\">Append</Value><Value code=\"1\">Create</Value><Value code=\"2\">Replace</Value><Value code=\"3\">Truncate</Value><Property contexts=\"target\" default=\"true\" description=\"Specifies whether to generate a create table statement at runtime\" filterProperty=\"/Usage/TableAction\" filterValue=\"1 2\" label=\"Generate create statement at runtime\" maxOccurs=\"1\" name=\"GenerateCreateStatement\" required=\"false\" type=\"bool\"><Property default=\"true\" description=\"Abort the job if there is an error executing a command\" label=\"Fail on error\" maxOccurs=\"1\" minOccurs=\"0\" name=\"FailOnError\" required=\"false\" type=\"bool\"/><Property default=\"false\" description=\"Select YES to read the CREATE statement from the file that is specified in the CREATE statement property.\" filterProperty=\"/Usage/TableAction/GenerateCreateStatement\" filterValue=\"false\" label=\"Read create statement from file\" maxOccurs=\"1\" minOccurs=\"0\" name=\"ReadCreateStatementFromFile\" required=\"false\" type=\"bool\"/><Property default=\"false\" description=\"Determines whether the target table is on Db2 LUW or Db2 for z/OS.\" label=\"Target table on Db2 for z/OS\" maxOccurs=\"1\" minOccurs=\"0\" name=\"CreateTableOnZOS\" required=\"false\" type=\"bool\"/><Property description=\"Identifies the database and/or table space in which the table is created: IN database-name.table-space-name. On Db2 LUW if required add CYCLE / NO CYCLE indication.\" label=\"In\" maxOccurs=\"1\" minOccurs=\"0\" name=\"CreateTableIn\" required=\"false\" type=\"string\"/><Property description=\"Specifies the table space in which indexes or long column values are to be stored (Db2 LUW only).\" filterProperty=\"/Usage/TableAction/GenerateCreateStatement/CreateTableOnZOS\" filterValue=\"false\" label=\"Index in\" maxOccurs=\"1\" minOccurs=\"0\" name=\"CreateTableIndexIn\" required=\"false\" type=\"string\"/><Property description=\"Specifies the buffer pool be use for the implicitly created table space and determines the page size of the table space. Do not specify BUFFERPOOL if the table space name is specified by using the IN table-space-name clause or the IN ACCELERATOR clause is specified. If you do not specify the BUFFERPOOL clause, Db2 selects the buffer pool as described in Implicitly defined table spaces (Db2 for z/OS only).\" filterProperty=\"/Usage/TableAction/GenerateCreateStatement/CreateTableOnZOS\" filterValue=\"true\" label=\"Buffer pool\" maxOccurs=\"1\" minOccurs=\"0\" name=\"CreateTableBufferpool\" required=\"false\" type=\"string\"/><Property default=\"0\" description=\"Specifies how the data is organized in the data pages of the table: row-organized table / column-organized table (Db2 LUW only).\" filterProperty=\"/Usage/TableAction/GenerateCreateStatement/CreateTableOnZOS\" filterValue=\"false\" label=\"Organize by\" name=\"CreateTableOrganizeBy\" required=\"false\" type=\"int\"><Value code=\"0\">Database default</Value><Value code=\"1\">Row</Value><Value code=\"2\">Column</Value></Property><Property default=\"0\" description=\"Specifies the database partitioning or the way the data is distributed across multiple database partitions (Db2 LUW only).\" filterProperty=\"/Usage/TableAction/GenerateCreateStatement/CreateTableOnZOS\" filterValue=\"false\" label=\"Distribute by\" name=\"CreateTableDistributeBy\" required=\"false\" type=\"int\"><Value code=\"0\">None</Value><Value code=\"1\">Hash</Value><Value code=\"2\">Random</Value><Property callout=\"allColumns\" calloutDescription=\"Click here to obtain the list of columns\" calloutLabel=\"Select columns\" calloutType=\"enumerator\" contexts=\"target\" description=\"A comma-separated list of key column names.\" filterProperty=\"/Usage/TableAction/GenerateCreateStatement/CreateTableDistributeBy\" filterValue=\"1\" label=\"Key columns\" maxOccurs=\"999999\" minOccurs=\"1\" multiline=\"true\" name=\"HashKeyColumns\" required=\"true\" type=\"string\" xsi:type=\"asc:CalloutProperty\"/></Property><Property default=\"0\" description=\"Specifies whether data compression applies to the rows. On DB2 for z/OS: if the IN table-space-name clause or the IN ACCELERATOR clause is specified, COMPRESS YES or COMPRESS NO must not be specified.\" label=\"Compress\" name=\"CreateTableCompress\" required=\"false\" type=\"int\"><Filter logic=\"or\"><FilterProperty logic=\"or\" property=\"/Usage/TableAction/GenerateCreateStatement/CreateTableOnZOS\">true</FilterProperty><Filter logic=\"and\"><FilterProperty logic=\"or\" property=\"/Usage/TableAction/GenerateCreateStatement/CreateTableOrganizeBy\">1</FilterProperty><FilterProperty logic=\"or\" property=\"/Usage/TableAction/GenerateCreateStatement/CreateTableOnZOS\">false</FilterProperty></Filter></Filter><Value code=\"0\">Database default</Value><Value code=\"1\">No</Value><Value code=\"2\">Yes</Value><Property default=\"0\" description=\"Specifies whether adaptive compression or classic row compression is used (Db2 LUW only).\" label=\"Type\" name=\"CreateTableCompressLUW\" required=\"false\" type=\"int\"><Filter logic=\"and\"><FilterProperty logic=\"or\" property=\"/Usage/TableAction/GenerateCreateStatement/CreateTableCompress\">2</FilterProperty><FilterProperty logic=\"or\" property=\"/Usage/TableAction/GenerateCreateStatement/CreateTableOnZOS\">false</FilterProperty></Filter><Value code=\"0\">Adaptive</Value><Value code=\"1\">Static</Value></Property></Property><Property default=\"false\" description=\"This determines the row format that is to be used. Each data type has a different byte count depending on the row format that is used (Db2 LUW only).\" label=\"Value compression\" maxOccurs=\"1\" minOccurs=\"0\" name=\"CreateTableValueCompression\" required=\"false\" type=\"bool\"><Filter logic=\"and\"><FilterProperty logic=\"or\" property=\"/Usage/TableAction/GenerateCreateStatement/CreateTableOrganizeBy\">1</FilterProperty><FilterProperty logic=\"or\" property=\"/Usage/TableAction/GenerateCreateStatement/CreateTableOnZOS\">false</FilterProperty></Filter></Property><Property default=\"\" description=\"Other options/clauses to the CREATE TABLE statement eg. Partitioning-clause.\" label=\"Other options\" maxLength=\"512\" minLength=\"0\" name=\"CreateTableOtherOptions\" required=\"false\" type=\"string\"/><Property contexts=\