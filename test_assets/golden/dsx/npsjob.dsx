<?xml version='1.0' encoding='UTF-16'?><Properties version='1.1'><Common><Context type='int'>1</Context><Variant type='string'>4.5</Variant><DescriptorVersion type='string'>1.0</DescriptorVersion><PartitionType type='int'>-1</PartitionType><RCP type='int'>0</RCP></Common><Connection><DataSource modified='1' type='string'><![CDATA[#prmLOTUS_DB.$envNzDataSrc#]]></DataSource><Database modified='1' type='string'><![CDATA[#prmLOTUS_DB.$envNzStgDb#]]></Database><Username modified='1' type='string'><![CDATA[#prmLOTUS_DB.$envNzStgUsrNm#]]></Username><Password modified='1' type='string'><![CDATA[#prmLOTUS_DB.$envNzStgPwd#]]></Password></Connection><Usage><GenerateSQL modified='1' type='bool'><![CDATA[0]]></GenerateSQL><EnableCaseSensitiveIDs type='bool'><![CDATA[0]]></EnableCaseSensitiveIDs><SQL><SelectStatement modified='1' type='string'><![CDATA[select  branch_sky,calendar_sky,
COUNT( CIF)  AS TOT_NPS_CON_REQ_ATT,
CAST(COUNT(CASE WHEN CONTRIBUTIONSTATUS='Contribution Success' THEN CIF END)AS INTEGER) AS TOT_NPS_CON_REQ_COMPLETED,
CAST(COUNT(CASE WHEN CONTRIBUTIONSTATUS='Contribution Success' THEN TOTALCOMMISSIONAMOUNT END)AS INTEGER) AS  TOT_COMMISSION
FROM comnstg.NPS_CONTRIBUTION_STG A
LEFT OUTER JOIN LOTUSDB_PRD.CUSDM.BRANCH_DIM B ON A.BRANCHCODE = B.BRANCH_NUM
LEFT OUTER JOIN LOTUSDB_PRD.CUSDM.CALENDAR_DIM C ON C.CALENDAR_DT= DATE(A.BUSINESS_DT)
where  DATE(A.BUSINESS_DT) ='#prmDateCntrl#'
group by 1,2
]]><ReadUserDefinedSQLFromFile type='bool'><![CDATA[0]]></ReadUserDefinedSQLFromFile></SelectStatement><EnablePartitionedReads type='bool'><![CDATA[0]]></EnablePartitionedReads></SQL><Transaction><RecordCount type='int'><![CDATA[2000]]></RecordCount><MarkEndOfWave type='bool'><![CDATA[0]]></MarkEndOfWave></Transaction><Session><SchemaReconciliation><UnmatchedLinkColumnActionSource type='int'><![CDATA[1]]></UnmatchedLinkColumnActionSource><TypeMismatchActionSource modified='1' type='int'><![CDATA[0]]></TypeMismatchActionSource><MismatchReportingActionSource type='int'><![CDATA[2]]></MismatchReportingActionSource></SchemaReconciliation><UnloadOptions></UnloadOptions></Session><BeforeAfterSQL collapsed='1' modified='1' type='bool'><![CDATA[0]]></BeforeAfterSQL><LimitRows collapsed='1' type='bool'><![CDATA[0]]></LimitRows></Usage></Properties >
=+=+=+=
      END DSSUBRECORD
