 to No, the statement errors will be ignored.\" label=\"Fail on error\" maxOccurs=\"1\" minOccurs=\"0\" name=\"FailOnError\" required=\"false\" type=\"bool\"><Property default=\"true\" description=\"If the atomic mode is yes, execute all statements in one transaction. Otherwise, execute each statement as separate transaction.\" filterProperty=\"/Usage/BeforeAfterSQL/AfterSQLNode/FailOnError\" filterValue=\"true\" label=\"Atomic Mode\" maxOccurs=\"1\" minOccurs=\"1\" name=\"AtomicMode\" required=\"false\" type=\"bool\"/><Property default=\"1\" description=\"The type of message that will be logged if a SQL statement fails.\" filterProperty=\"/Usage/BeforeAfterSQL/AfterSQLNode/FailOnError\" filterValue=\"false\" label=\"Message type for statement errors\" maxOccurs=\"1\" minOccurs=\"0\" name=\"LogLevelForAfterSQLNode\" required=\"false\" type=\"int\"><Value code=\"0\">None</Value><Value code=\"1\">Warning</Value><Value code=\"2\">Info</Value></Property></Property></Property></Property><Property contexts=\"source\" default=\"false\" description=\"Select Yes to limit the number of rows that are returned by the connector.\" filterChildPropertiesOnValue=\"true\" label=\"Limit number of returned rows\" name=\"LimitRows\" required=\"false\" type=\"bool\"><Property default=\"1000\" description=\"Enter the maximum number of rows that will be returned by the connector.\" label=\"Limit\" minValue=\"1\" name=\"Limit\" required=\"false\" type=\"int\"/></Property></Usage></Properties><MetaBag><MetaProperty Name=\"InputLinkOrder\" Owner=\"APT\" Value=\"Input#\"/><MetaProperty Name=\"OutputLinkOrder\" Owner=\"APT\" Value=\"!Input#\"/></MetaBag><ModelMappings><DataConnection><ConnectionString>/Connection/DataSource</ConnectionString><Username>/Connection/Username</Username><Password>/Connection/Password</Password><Private name=\"Database\">/Connection/Database</Private><Private name=\"UseSeparateConnectionForTWT\" usage=\"runtime\">/Connection/UseSeparateConnectionForTWT</Private><Pri