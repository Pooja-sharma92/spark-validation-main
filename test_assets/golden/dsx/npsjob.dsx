      BEGIN DSSUBRECORD
         Name "XMLConnectorDescriptor"
         DisplayStyle "0"
         DisplayCaption "XMLConnectorDescriptor"
         Default "<?xml version=\"1.0\"?><asc:Connector xmlns:asc=\"http://www.ibm.com\" schemaVersion=\"1.0\" version=\"1.0\" xmlns:xsi=\"http://www.w3.org/2001/XMLSchema-instance\" xsi:schemaLocation=\"http://www.ibm.com ../CC_Common/XML/CC_Connector.xsd\"><MetaData><Id>NetezzaConnector</Id><Type>database</Type><DisplayName>Netezza Connector</DisplayName><Description><ShortVersion>Netezza Connector</ShortVersion><LongVersion>This connector is used for accessing data in Netezza databases</LongVersion></Description><Author>IBM Corp.</Author><Vendor>IBM Corp.</Vendor><Copyright>Licensed Materials - Property of IBM, (C) Copyright IBM Corp. 2011, 2019 All Rights Reserved.</Copyright><Icons><SmallVersion>NetezzaConnector.bmp</SmallVersion><LargeVersion>NetezzaConnectors.bmp</LargeVersion></Icons><DependentLibraries/><ImportClasses/></MetaData><Variants><Variant><Name>4.5</Name><Library>ccnz</Library><Version>1.0</Version></Variant></Variants><Capabilities><SupportedEngines>ee se</SupportedEngines><SupportedPlatforms><Platform level=\"XP\" mode=\"32\">windows</Platform></SupportedPlatforms><SupportedContexts>source target request</SupportedContexts><SupportedTransactionModels><Local/></SupportedTransactionModels><SupportsBrowsing>source target</SupportsBrowsing><Listener>none</Listener><ConnectionScope>thread</ConnectionScope><Reject><SupportedContexts/><RejectConditions/><DataElements/></Reject><SeCapabilities><RepositoryLocation>\\Stage Types\\Server\\Database</RepositoryLocation><StageType>passive</StageType><SupportsRef>true</SupportsRef><InputLinks max=\"1\" min=\"0\"/><OutputLinks max=\"1\" min=\"0\"/><RejectLinks max=\"0\" min=\"0\"/><SuperIconName>NETEZZA</SuperIconName><SuperIconDefaultPriority>95</SuperIconDefaultPriority><HelpLinks><Topic>com.ibm.swg.im.iis.conn.netezza.help.doc</Topic><Link id=\"12\">topics/nzcc_properties.html</Link><Link id=\"13\">topics/nzcc_properties.html</Link></HelpLinks></SeCapabilities><PxCapabilities><RepositoryLocation>\\Stage Types\\Parallel\\Database</RepositoryLocation><StageType>passive</StageType><SupportsRef>true</SupportsRef><InputLinks max=\"1\" min=\"0\"/><RejectLinks max=\"0\" min=\"0\"/><SuperIconName>NETEZZA</SuperIconName><SuperIconDefaultPriority>95</SuperIconDefaultPriority><HelpLinks><Topic>com.ibm.swg.im.iis.conn.netezza.help.doc</Topic><Link id=\"12\">topics/nzcc_properties.html</Link><Link id=\"13\">topics/nzcc_properties.html</Link></HelpLinks><SupportedLookupTypes/></PxCapabilities></Capabilities><MetaDataImport><Connection><Property callout=\"getList\" calloutDescription=\"Click here to obtain the list of ODBC service names that can be used to connect to the Netezza database.\" calloutLabel=\"Select\" calloutType=\"enumerator\" description=\"Specify the data source name as it is defined in the ODBC driver manager.\" label=\"Data source\" maxLength=\"256\" maxOccurs=\"1\" minLength=\"1\" minOccurs=\"0\" name=\"DataSource\" required=\"true\" type=\"string\" xsi:type=\"asc:CalloutProperty\"><CalloutArgument name=\"class\">DataSources</CalloutArgument></Property><Property description=\"Specify the name of the database to connect to.\" label=\"Database\" maxLength=\"256\" maxOccurs=\"1\" minLength=\"1\" minOccurs=\"0\" name=\"Database\" required=\"false\" type=\"string\"/><Property description=\"Specify the user name to use to connect to the database.\" label=\"User name\" maxLength=\"256\" maxOccurs=\"1\" minLength=\"1\" minOccurs=\"1\" name=\"Username\" required=\"true\" type=\"string\"/><Property description=\"Specify the password to use to connect to the database.\" label=\"Password\" maxLength=\"256\" maxOccurs=\"1\" minLength=\"1\" minOccurs=\"1\" name=\"Password\" required=\"true\" type=\"protectedstring\"/></Connection><SchemaClasses><Class description=\"Generate schema to represent a database table\" label=\"Data Collection\" name=\"DataCollection\"><Connection/><Group description=\"Specify filter properties\" label=\"Filter\" name=\"Filter\"><Property callout=\"getList\" calloutDescription=\"Select table or view schema\" calloutLabel=\"Schema\" calloutType=\"enumerator\" copyValueTo=\"/MetaDataImport/NonSchemaClasses/DataCollections/Filter/schema\" default=\"\" description=\"Filter by collection schema\" label=\"Schema\" maxOccurs=\"1\" minOccurs=\"0\" name=\"schema\" required=\"false\" type=\"string\" xsi:type=\"asc:CalloutProperty\"><CalloutArgument name=\"class\">DataSchemas</CalloutArgument></Property><Property copyValueTo=\"/MetaDataImport/NonSchemaClasses/DataCollections/Filter/includeTables\" default=\"true\" description=\"Specify whether to include tables in the list of objects to be imported.\" label=\"Include tables\" maxOccurs=\"1\" minOccurs=\"0\" name=\"includeTables\" required=\"false\" type=\"bool\"/><Property copyValueTo=\"/MetaDataImport/NonSchemaClasses/DataCollections/Filter/includeViews\" default=\"true\" description=\"Specify whether to include views in the list of objects to be imported.\" label=\"Include views\" maxOccurs=\"1\" minOccurs=\"0\" name=\"includeViews\" required=\"false\" type=\"bool\"/><Property copyValueTo=\"/MetaDataImport/NonSchemaClasses/DataCollections/Filter/includeSystemObjects\" default=\"true\" description=\"Include system objects.\" label=\"Include system objects\" maxOccurs=\"1\" minOccurs=\"0\" name=\"includeSystemObjects\" required=\"false\" type=\"bool\"/><Property copyValueTo=\"/MetaDataImport/NonSchemaClasses/DataCollections/Filter/includeSynonyms\" default=\"true\" description=\"Include synonyms in the import.\" label=\"Include synonyms\" maxOccurs=\"1\" minOccurs=\"0\" name=\"includeSynonyms\" required=\"false\" type=\"bool\"/><Property copyValueTo=\"/MetaDataImport/NonSchemaClasses/DataCollections/Filter/includeMaterializedViews\" default=\"true\" description=\"Include materialized views in the import.\" label=\"Include materialized views\" maxOccurs=\"1\" minOccurs=\"0\" name=\"includeMaterializedViews\" required=\"false\" type=\"bool\"/><Property copyValueTo=\"/MetaDataImport/NonSchemaClasses/DataCollections/Filter/includeExternalTables\" default=\"true\" description=\"Include external tables in the import.\" label=\"Include external tables\" maxOccurs=\"1\" minOccurs=\"0\" name=\"includeExternalTables\" required=\"false\" type=\"bool\"/><Property copyValueTo=\"/MetaDataImport/NonSchemaClasses/DataCollections/Filter/nameFilter\" default=\"\" description=\"Filter by collection name\" label=\"Name filter\" maxOccurs=\"1\" minOccurs=\"0\" name=\"nameFilter\" required=\"false\" type=\"string\"/></Group><Group description=\"Specify selection properties\" label=\"Selection\" name=\"Selection\"><Property callout=\"query\" calloutDescription=\"Select table or view\" calloutLabel=\"Table or view\" calloutType=\"enumerator\" description=\"Collection name\" label=\"Name\" maxOccurs=\"1\" minOccurs=\"1\" name=\"name\" required=\"true\" type=\"string\" xsi:type=\"asc:CalloutProperty\"><CalloutArgument name=\"class\">DataCollections</CalloutArgument></Property><Property default=\"\" hidden=\"true\" maxOccurs=\"1\" minOccurs=\"0\" name=\"schema\" required=\"false\" type=\"string\"/></Group></Class><Class description=\"Import data collections.\" label=\"Bulk data collections\" name=\"BulkDataCollections\"><Group description=\"Specify filter properties\" label=\"Filter\" name=\"SubtypeFilter\"><Property default=\"true\" description=\"Specify whether to include tables in the list of objects to be imported.\" label=\"Include tables\" maxOccurs=\"1\" minOccurs=\"0\" name=\"includeTables\" required=\"false\" type=\"bool\"/><Property default=\"true\" description=\"Specify whether to include views in the list of objects to be imported.\" label=\"Include views\" maxOccurs=\"1\" minOccurs=\"0\" name=\"includeViews\" required=\"false\" type=\"bool\"/><Property default=\"true\" description=\"Include synonyms in the import.\" label=\"Include synonyms\" maxOccurs=\"1\" minOccurs=\"0\" name=\"includeSynonyms\" required=\"false\" type=\"bool\"/><Property default=\"true\" description=\"Include materialized views in the import.\" label=\"Include materialized views\" maxOccurs=\"1\" minOccurs=\"0\" name=\"includeMaterializedViews\" required=\"false\" type=\"bool\"/><Property default=\"true\" description=\"Include external tables in the import.\" label=\"Include external tables\" maxOccurs=\"1\" minOccurs=\"0\" name=\"includeExternalTables\" required=\"false\" type=\"bool\"/></Group></Class></SchemaClasses><NonSchemaClasses><Class description=\"Obtain information about database\" label=\"Database\" name=\"Database\"><Connection/><Attributes><Attribute>vendor</Attribute><Attribute>version</Attribute><Attribute>DBMS</Attribute><Attribute>path</Attribute><Attribute>server</Attribute><Attribute>host</Attribute></Attributes></Class><Class description=\"Obtain a list of available schema\" label=\"Data schemas\" name=\"DataSchemas\"><Connection/><Attributes><Attribute>owner</Attribute></Attributes></Class><Class description=\"Obtain a list of data collections\" label=\"Data collections\" name=\"DataCollections\"><Connection/><Attributes><Attribute>schema</Attribute><Attribute>nameQualifier</Attribute><Attribute>subType</Attribute><Attribute>isView</Attribute><Attribute>viewExpression</Attribute><Attribute>nameQuotingChar</Attribute><Attribute>isSystem</Attribute></Attributes><Group description=\"Specify filter properties\" label=\"Filter\" name=\"Filter\"><Property callout=\"getList\" calloutDescription=\"Select table or view schema\" calloutLabel=\"Schema\" calloutType=\"enumerator\" default=\"\" description=\"Filter by collection schema\" label=\"Schema\" maxOccurs=\"1\" minOccurs=\"0\" name=\"schema\" required=\"false\" type=\"string\" xsi:type=\"asc:CalloutProperty\"><CalloutArgument name=\"class\">DataSchemas</CalloutArgument></Property><Property default=\"true\" description=\"Specify whether to include tables in the list of objects to be imported.\" label=\"Include tables\" maxOccurs=\"1\" minOccurs=\"0\" name=\"includeTables\" required=\"false\" type=\"bool\"/><Property default=\"true\" description=\"Specify whether to include views in the list of objects to be imported.\" label=\"Include views\" maxOccurs=\"1\" minOccurs=\"0\" name=\"includeViews\" required=\"false\" type=\"bool\"/><Property default=\"true\" description=\"Include system objects.\" label=\"Include system objects\" maxOccurs=\"1\" minOccurs=\"0\" name=\"includeSystemObjects\" required=\"false\" type=\"bool\"/><Property default=\"true\" description=\"Include synonyms in the import.\" label=\"Include synonyms\" maxOccurs=\"1\" minOccurs=\"0\" name=\"includeSynonyms\" required=\"false\" type=\"bool\"/><Property default=\"true\" description=\"Include materialized views in the import.\" label=\"Include materialized views\" maxOccurs=\"1\" minOccurs=\"0\" name=\"includeMaterializedViews\" required=\"false\" type=\"bool\"/><Property default=\"true\" description=\"Include external tables in the import.\" label=\"Include external tables\" maxOccurs=\"1\" minOccurs=\"0\" name=\"includeExternalTables\" required=\"false\" type=\"bool\"/><Property default=\"\" description=\"Filter by collection name\" label=\"Name filter\" maxOccurs=\"1\" minOccurs=\"0\" name=\"nameFilter\" required=\"false\" type=\"string\"/></Group></Class><Class description=\"Obtain a list of related collections\" label=\"Related data collections\" name=\"RelatedDataCollections\"><Connection/><Group description=\"Specify filter properties\" label=\"Filter\" name=\"Filter\"><Property default=\"\" description=\"Collection name\" label=\"Name\" name=\"name\" required=\"true\" type=\"string\"/><Property default=\"\" hidden=\"true\" maxOccurs=\"1\" minOccurs=\"0\" name=\"schema\" required=\"false\" type=\"string\"/><Property default=\"true\" description=\"Include tables whose primary keys are pointed to by foreign keys in this table\" label=\"Include parents\" maxOccurs=\"1\" minOccurs=\"0\" name=\"includeParents\" required=\"false\" type=\"bool\"/><Property default=\"true\" description=\"Include tables whose foreign keys point to this table's primary key\" label=\"Include children\" maxOccurs=\"1\" minOccurs=\"0\" name=\"includeChildren\" required=\"false\" type=\"bool\"/></Group></Class><Class description=\"Obtain a list of data sources\" label=\"Data sources\" name=\"DataSources\"><Attributes><Attribute>isSystem</Attribute><Attribute>description</Attribute></Attributes><Group description=\"Specify properties\" label=\"Properties\" name=\"Properties\"><Property default=\"true\" description=\"Include user DSNs in the list of data sources\" label=\"Include user DSNs\" maxOccurs=\"1\" minOccurs=\"0\" name=\"includeUserDSNs\" required=\"false\" type=\"bool\"/><Property default=\"true\" description=\"Include system DSNs in the list of data sources\" label=\"Include system DSNs\" maxOccurs=\"1\" minOccurs=\"0\" name=\"includeSystemDSNs\" required=\"false\" type=\"bool\"/><Property default=\"true\" description=\"Enable Unicode API calls\" label=\"Enable Unicode\" maxOccurs=\"1\" minOccurs=\"0\" name=\"isUnicode\" required=\"false\" type=\"bool\"/></Group></Class><Class description=\"Obtain a list of users for the current database\" label=\"Users\" name=\"Users\"><Connection/></Class></NonSchemaClasses></MetaDataImport><Properties><Connection><Property callout=\"getList\" calloutDescription=\"Click here to obtain the list of ODBC service names that can be used to connect to the Netezza database.\" calloutLabel=\"Select\" calloutType=\"enumerator\" description=\"Specify the data source name as it is defined in the ODBC driver manager.\" label=\"Data source\" maxLength=\"256\" maxOccurs=\"1\" minLength=\"1\" minOccurs=\"0\" name=\"DataSource\" required=\"true\" type=\"string\" xsi:type=\"asc:CalloutProperty\"><CalloutArgument name=\"class\">DataSources</CalloutArgument></Property><Property description=\"Specify the name of the database to connect to.\" label=\"Database\" maxLength=\"256\" maxOccurs=\"1\" minLength=\"1\" minOccurs=\"0\" name=\"Database\" required=\"true\" type=\"string\"/><Property description=\"Specify the user name to use to connect to the database.\" label=\"User name\" maxLength=\"256\" maxOccurs=\"1\" minLength=\"1\" minOccurs=\"1\" name=\"Username\" required=\"true\" type=\"string\"/><Property description=\"Specify the password to use to connect to the database.\" label=\"Password\" maxLength=\"256\" maxOccurs=\"1\" minLength=\"1\" minOccurs=\"1\" name=\"Password\" required=\"true\" type=\"protectedstring\"/><Property contexts=\"target\" default=\"false\" description=\"Use a separate connection for creating/dropping/accessing External tables (ETs) and the Temporary Work Table.\" filterChildPropertiesOnValue=\"true\" label=\"Use separate connection for TWT\" maxOccurs=\"1\" minOccurs=\"0\" name=\"UseSeparateConnectionForTWT\" required=\"true\" type=\"bool\"><Property description=\"The name of the database for ETs and TWT.\" label=\"Database\" maxLength=\"256\" maxOccurs=\"1\" minLength=\"1\" minOccurs=\"0\" name=\"Database\" required=\"true\" type=\"string\"/><Property description=\"Name of the user for authentication purposes.\" label=\"User name\" maxLength=\"256\" maxOccurs=\"1\" minLength=\"1\" minOccurs=\"1\" name=\"Username\" required=\"false\" type=\"string\"/><Property description=\"Password for authentication purposes.\" label=\"Password\" maxLength=\"256\" maxOccurs=\"1\" minLength=\"1\" minOccurs=\"1\" name=\"Password\" required=\"false\" type=\"protectedstring\"/></Property></Connection><Usage><Property contexts=\"target\" default=\"0\" description=\"Type of the SQL statement (or statements) to be executed.\" label=\"Write mode\" maxOccurs=\"1\" minOccurs=\"1\" name=\"WriteMode\" required=\"false\" type=\"int\"><Value code=\"0\">Insert</Value><Value code=\"1\">Update</Value><Value code=\"2\">Delete</Value><Value code=\"4\">Update then insert</Value><Value code=\"5\">Delete then insert</Value><Value code=\"10\">Action column</Value><Value code=\"7\">User-defined SQL</Value></Property><Property contexts=\"source request\" default=\"true\" description=\"Indicates whether the connector should generate a SELECT statement or use the provided SQL statement.\" label=\"Generate SQL at runtime\" maxOccurs=\"1\" minOccurs=\"0\" name=\"GenerateSQL\" required=\"false\" type=\"bool\"/><Property contexts=\"all\" description=\"The name of the target table. This table name will be used in the generated SQL statement(s). Never enter the name with quotes.\" label=\"Table name\" maxOccurs=\"1\" minOccurs=\"1\" name=\"TableName\" required=\"true\" type=\"string\"><Filter logic=\"or\"><FilterProperty logic=\"or\" property=\"/Usage/GenerateSQL\">true</FilterProperty><FilterProperty logic=\"or\" property=\"/Usage/WriteMode\">0 1 2 4 5 7 10</FilterProperty></Filter></Property><Property default=\"false\" description=\"If set to Yes, table and column names will be assumed to be case sensitive.\" label=\"Enable case-sensitive identifiers\" maxOccurs=\"1\" minOccurs=\"1\" name=\"EnableCaseSensitiveIDs\" required=\"false\" type=\"bool\"/><Property contexts=\"target\" default=\"false\" description=\"If Set to Yes, the names of the input link columns will be truncated.\" filterChildPropertiesOnValue=\"true\" label=\"Truncate column names\" maxOccurs=\"1\" minOccurs=\"1\" name=\"TruncateColumnNames\" required=\"false\" type=\"bool\"><Property contexts=\"target\" default=\"128\" description=\"The maximum length in characters of column names after truncation.\" label=\"Truncate length\" maxValue=\"128\" minValue=\"1\" name=\"TruncateLength\" required=\"true\" type=\"int\"/></Property><Property description=\"SQL statement properties.\" label=\"SQL\" maxOccurs=\"1\" minOccurs=\"0\" name=\"SQL\" required=\"false\" type=\"category\"><Property contexts=\"target\" default=\"false\" description=\"If set to Yes, the connector insert directly into the target table. In this mode, when running with multiple processing nodes it is possible to have partially committed data if one or more of the processing nodes encounters an error. If set No, the connector inserts into the temporary work table (TWT) first and then from TWT into the target. In this mode the data will either be completely committed or completely rolled back guarantying consistency.\" filterProperty=\"/Usage/WriteMode\" filterValue=\"0\" label=\"Direct insert\" maxOccurs=\"1\" minOccurs=\"1\" name=\"DirectInsert\" required=\"false\" type=\"bool\"/><Property contexts=\"target\" default=\"true\" description=\"When set to Yes, all write mode statements will be executed in one transaction. If set to No, each statement will be executed in a separate transaction.\" filterProperty=\"/Usage/WriteMode\" filterValue=\"4 5 7 10\" label=\"Atomic mode\" maxOccurs=\"1\" minOccurs=\"1\" name=\"AtomicMode\" required=\"false\" type=\"bool\"/><Property contexts=\"target\" default=\"false\" description=\"Setting it to Yes, enables record ordering and enables child properties for specifying order columns\" filterChildPropertiesOnValue=\"true\" filterProperty=\"/Usage/WriteMode\" filterValue=\"0 4 5 10\" label=\"Enable record ordering\" maxOccurs=\"1\" minOccurs=\"0\" name=\"EnableRecordOrdering\" required=\"false\" type=\"bool\"><Filter logic=\"or\"><FilterProperty logic=\"or\" property=\"/Usage/WriteMode\">4 5 10</FilterProperty><Filter logic=\"and\"><FilterProperty logic=\"or\" property=\"/Usage/SQL/DirectInsert\">false</FilterProperty><FilterProperty logic=\"or\" property=\"/Usage/WriteMode\">0</FilterProperty></Filter></Filter><Property description=\"Ordering key\" label=\"Key\" maxOccurs=\"999999\" minOccurs=\"1\" name=\"OrderKey\" required=\"false\" type=\"category\"><Property callout=\"allColumns\" calloutDescription=\"Click here to obtain the list of columns\" calloutLabel=\"Select columns\" calloutType=\"enumerator\" description=\"The name of the column representing the ordering key\" label=\"Column name\" maxOccurs=\"1\" minOccurs=\"1\" multiline=\"false\" name=\"ColumnName\" required=\"false\" type=\"string\" xsi:type=\"asc:CalloutProperty\"/></Property></Property><Property contexts=\"source request\" description=\"Enter a SELECT statement. The statement is used to read rows from the database.\" filterProperty=\"/Usage/GenerateSQL\" filterValue=\"false\" label=\"Select statement\" maxOccurs=\"1\" minOccurs=\"1\" multiline=\"true\" name=\"SelectStatement\" required=\"true\" type=\"string\"><Callouts><Callout callout=\"generateSQL\" calloutFilterProperty=\"/Usage/SQL/SelectStatement/ReadUserDefinedSQLFromFile\" calloutFilterValue=\"1\" calloutLabel=\"Generate statement\" calloutType=\"builder\"><CalloutArgument name=\"statementType\">SelectStatementSQL</CalloutArgument></Callout></Callouts><Property default=\"false\" description=\"If set to Yes, the User-defined SQL property specifies a file name/path containing the SQL statement.\" label=\"Read user-defined SQL from file\" maxOccurs=\"1\" minOccurs=\"1\" name=\"ReadUserDefinedSQLFromFile\" required=\"false\" type=\"bool\"/></Property><Property contexts=\"source\" default=\"false\" description=\"If set to Yes, the connector will allow reading in parallel. The level of parallelism will be determined by the number of nodes in the APT configuration file. If set to No, the connector will force sequential execution.\" label=\"Enable partitioned reads\" maxOccurs=\"1\" minOccurs=\"1\" name=\"EnablePartitionedReads\" required=\"false\" type=\"bool\"/><Property callout=\"allColumns\" calloutDescription=\"Click here to obtain the list of columns\" calloutLabel=\"Select columns\" calloutType=\"enumerator\" contexts=\"target\" description=\"A comma-separated list of key column names.\" label=\"Key columns\" maxOccurs=\"999999\" minOccurs=\"1\" multiline=\"true\" name=\"KeyColumns\" required=\"true\" type=\"string\" xsi:type=\"asc:CalloutProperty\"><Filter logic=\"or\"><FilterProperty logic=\"or\" property=\"/Usage/SQL/CheckDuplicateRows\">1</FilterProperty><FilterProperty logic=\"or\" property=\"/Usage/WriteMode\">1 2 4 5 10</FilterProperty></Filter></Property><Property contexts=\"target\" default=\"false\" description=\"When set to Yes, the connector will generate an update statement that uses the unique key specified below. When set to No, the connector will generate a simpler update statement that does not use a unique column.\" filterChildPropertiesOnValue=\"true\" label=\"Use unique key column\" maxOccurs=\"1\" minOccurs=\"1\" name=\"UseUniqueKeyColumn\" required=\"false\" type=\"bool\"><Filter logic=\"or\"><FilterProperty logic=\"or\" property=\"/Usage/SQL/CheckDuplicateRows\">1</FilterProperty><FilterProperty logic=\"or\" property=\"/Usage/WriteMode\">1 4</FilterProperty></Filter><Property callout=\"allColumns\" calloutDescription=\"Select one of these type of columns as Unique Key: date, time, timestamp or serial number\" calloutLabel=\"Select columns\" calloutType=\"enumerator\" contexts=\"target\" description=\"The name of the unique key column.\" label=\"Unique Key column\" maxOccurs=\"1\" minOccurs=\"1\" multiline=\"true\" name=\"UniqueKeyColumn\" required=\"true\" type=\"string\" xsi:type=\"asc:CalloutProperty\"/></Property><Property callout=\"allColumns\" calloutDescription=\"Click here to obtain the list of columns\" calloutLabel=\"Select columns\" calloutType=\"enumerator\" contexts=\"target\" description=\"A comma-separated list of column names whose value will be updated by the statement(s).\" filterProperty=\"/Usage/WriteMode\" filterValue=\"1 4 10\" label=\"Update columns\" maxOccurs=\"999999\" minOccurs=\"1\" multiline=\"true\" name=\"UpdateColumns\" required=\"false\" type=\"string\" xsi:type=\"asc:CalloutProperty\"/><Property callout=\"datatypeColumns\" calloutDescription=\"Click here to obtain the char type columns\" calloutLabel=\"Select columns\" calloutType=\"enumerator\" contexts=\"target\" description=\"The name of the char(1) column that identifies one of the action the row should participate in.\" filterProperty=\"/Usage/WriteMode\" filterValue=\"10\" label=\"Action column\" maxOccurs=\"1\" minOccurs=\"1\" multiline=\"true\" name=\"ActionColumn\" required=\"true\" type=\"string\" xsi:type=\"asc:CalloutProperty\"><CalloutArgument name=\"includedDatatypes\">1</CalloutArgument></Property><Property contexts=\"target\" default=\"false\" description=\"When set to Yes, the connector detects duplicate rows. When set to No (Default), the connector does not detect duplicate rows.\" filterChildPropertiesOnValue=\"true\" label=\"Check duplicate rows\" maxOccurs=\"1\" minOccurs=\"1\" name=\"CheckDuplicateRows\" required=\"false\" type=\"bool\"><Filter logic=\"or\"><FilterProperty logic=\"or\" property=\"/Usage/WriteMode\">1 4 5 10</FilterProperty><Filter logic=\"and\"><FilterProperty logic=\"or\" property=\"/Usage/SQL/DirectInsert\">false</FilterProperty><FilterProperty logic=\"or\" property=\"/Usage/WriteMode\">0</FilterProperty></Filter></Filter><Property contexts=\"target\" default=\"0\" description=\"When set to Filter (Default), the connector filters out duplicate rows. When set to Fail, the job fails if any duplicate rows are found without making changes to the target table.\" label=\"Duplicate row action\" maxOccurs=\"1\" minOccurs=\"1\" name=\"DuplicateRowAction\" required=\"false\" type=\"int\"><Value code=\"0\">Filter</Value><Value code=\"1\">Fail</Value></Property></Property><Property contexts=\"target\" description=\"These SQL statements in general should update the target table using the data in the temporary work table.\" filterProperty=\"/Usage/WriteMode\" filterValue=\"7\" label=\"User-defined SQL\" maxOccurs=\"1\" minOccurs=\"1\" multiline=\"true\" name=\"UserDefinedSQL\" required=\"true\" type=\"string\"><Property contexts=\"target\" default=\"false\" description=\"If set to Yes, the User-defined SQL property specifies a file name/path containing the SQL statement.\" filterProperty=\"/Usage/WriteMode\" filterValue=\"7\" label=\"Read user-defined SQL from file\" maxOccurs=\"1\" minOccurs=\"1\" name=\"ReadUserDefinedSQLFromFile\" required=\"false\" type=\"bool\"/></Property></Property><Property contexts=\"target\" default=\"0\" description=\"Select the action to perform before writing data to the table.\" filterProperty=\"/Usage/WriteMode\" filterValue=\"0 7 10\" label=\"Table action\" maxOccurs=\"1\" minOccurs=\"0\" name=\"TableAction\" required=\"true\" type=\"int\"><Value code=\"0\">Append</Value><Value code=\"1\">Create</Value><Value code=\"2\">Replace</Value><Value code=\"3\">Truncate</Value><Property contexts=\"target\" default=\"true\" description=\"If set to Yes, the CREATE TABLE statement will be generated by the connector at runtime based on the columns in the input link and the table name provided in the Table name property\" filterProperty=\"/Usage/TableAction\" filterValue=\"1 2\" label=\"Generate create statement at runtime\" maxOccurs=\"1\" name=\"GenerateCreateStatement\" required=\"false\" type=\"bool\"><Property default=\"1\" description=\"If set to Automatic, the Netezza server will choose the key. There is no guaranty which columns will be used and the feature can vary between Netezza software releases. If set to Random, rows will be sent to processing nodes in a random fashion (key-less). If set to User-defined, the columns listed in Key columns below will be used as a distribution key. This property only applies to a generated CREATE TABLE statement (run-time or design-time) and has no effect if the statement is entered manually\" label=\"Distribution key\" maxOccurs=\"1\" minOccurs=\"0\" name=\"DistributionKey\" required=\"false\" type=\"int\"><Filter logic=\"or\"><FilterProperty logic=\"or\" property=\"/Usage/TableAction/GenerateCreateStatement/ReadCreateStatementFromFile\">false</FilterProperty><FilterProperty logic=\"or\" property=\"/Usage/TableAction/GenerateCreateStatement\">true</FilterProperty></Filter><Value code=\"0\">Automatic</Value><Value code=\"1\">Random</Value><Value code=\"2\">User-defined</Value><Property callout=\"allColumns\" calloutDescription=\"Click here to obtain the list of columns\" calloutLabel=\"Select columns\" calloutType=\"enumerator\" default=\"\" description=\"Comma-separated list of column names that should comprise the distribution key.\" filterProperty=\"/Usage/TableAction/GenerateCreateStatement/DistributionKey\" filterValue=\"2\" label=\"Key columns\" maxOccurs=\"999999\" minOccurs=\"0\" multiline=\"true\" name=\"KeyColumns\" required=\"true\" type=\"string\" xsi:type=\"asc:CalloutProperty\"/></Property><Property default=\"true\" description=\"If set to Yes, the job will be aborted if the create statement failed (for example if the table exists already). If set to No, the statement errors will be ignored.\" filterChildPropertiesOnValue=\"false\" label=\"Fail on error\" maxOccurs=\"1\" minOccurs=\"0\" name=\"FailOnError\" required=\"false\" type=\"bool\"><Property default=\"1\" description=\"The type of message that will be logged if a SQL statement fails.\" label=\"Message type for statement errors\" maxOccurs=\"1\" minOccurs=\"0\" name=\"LogLevelForCreateStatement\" required=\"false\" type=\"int\"><Value code=\"0\">None</Value><Value code=\"1\">Warning</Value><Value code=\"2\">Info</Value></Property></Property><Property default=\"false\" description=\"If set to Yes, the Create statement property specifies a file name/path containing the SQL statement.\" filterProperty=\"/Usage/TableAction/GenerateCreateStatement\" filterValue=\"false\" label=\"Read create statement from file\" maxOccurs=\"1\" minOccurs=\"0\" name=\"ReadCreateStatementFromFile\" required=\"false\" type=\"bool\"/><Property default=\"\" description=\"Specifies a user-defined CREATE TABLE statement.\" filterProperty=\"/Usage/TableAction/GenerateCreateStatement\" filterValue=\"false\" label=\"Create statement\" maxOccurs=\"1\" minOccurs=\"0\" multiline=\"true\" name=\"CreateStatement\" required=\"true\" type=\"string\"><Callouts><Callout callout=\"generateSQL\" calloutFilterProperty=\"/Usage/TableAction/GenerateCreateStatement/ReadCreateStatementFromFile\" calloutFilterValue=\"1\" calloutLabel=\"Generate statement\" calloutType=\"builder\"><CalloutArgument name=\"statementType\">CreateTableSQL</CalloutArgument></Callout></Callouts></Property></Property><Property contexts=\"target\" default=\"true\" description=\"If set the Yes, the DROP TABLE statement will be generated at runtime. If set to No, the user needs to provide a custom statement in the Drop statement property.\" filterProperty=\"/Usage/TableAction\" filterValue=\"2\" label=\"Generate drop statement at runtime\" maxOccurs=\"1\" minOccurs=\"0\" name=\"GenerateDropStatement\" required=\"false\" type=\"bool\"><Property default=\"false\" description=\"If set to Yes, the job will be aborted if the drop statement failed (for example if the table did not exists already). If set to No, the statement errors will be ignored.\" filterChildPropertiesOnValue=\"false\" label=\"Fail on error\" maxOccurs=\"1\" minOccurs=\"0\" name=\"FailOnError\" required=\"false\" type=\"bool\"><Property default=\"1\" description=\"The type of message that will be logged if a SQL statement fails.\" label=\"Message type for statement errors\" maxOccurs=\"1\" minOccurs=\"0\" name=\"LogLevelForDropStatement\" required=\"false\" type=\"int\"><Value code=\"0\">None</Value><Value code=\"1\">Warning</Value><Value code=\"2\">Info</Value></Property></Property><Property default=\"false\" description=\"If set to Yes, the Drop statement property specifies a file name/path containing the SQL statement. Otherwise it specifies the actual SQL statement.\" filterProperty=\"/Usage/TableAction/GenerateDropStatement\" filterValue=\"false\" label=\"Read drop statement from file\" maxOccurs=\"1\" minOccurs=\"0\" name=\"ReadDropStatementFromFile\" required=\"false\" type=\"bool\"/><Property contexts=\"target\" default=\"\" description=\"Specifies a user-defined DROP TABLE statement.\" filterProperty=\"/Usage/TableAction/GenerateDropStatement\" filterValue=\"false\" label=\"Drop statement\" maxOccurs=\"1\" minOccurs=\"0\" multiline=\"true\" name=\"DropStatement\" required=\"true\" type=\"string\"><Callouts><Callout callout=\"generateSQL\" calloutFilterProperty=\"/Usage/TableAction/GenerateDropStatement/ReadDropStatementFromFile\" calloutFilterValue=\"1\" calloutLabel=\"Generate statement\" calloutType=\"builder\"><CalloutArgument name=\"statementType\">DropTableSQL</CalloutArgument></Callout></Callouts></Property></Property><Property contexts=\"target\" default=\"true\" description=\"If set the Yes, the TRUNCATE TABLE statement will be generated at runtime.\" filterProperty=\"/Usage/TableAction\" filterValue=\"3\" label=\"Generate truncate statement at runtime\" maxOccurs=\"1\" name=\"GenerateTruncateStatement\" required=\"false\" type=\"bool\"><Property default=\"true\" description=\"If set to Yes, the job will be aborted if the truncate statement failed (for example if the table exists already). If set to No, the statement errors will be ignored.\" filterChildPropertiesOnValue=\"false\" label=\"Fail on error\" maxOccurs=\"1\" minOccurs=\"0\" name=\"FailOnError\" required=\"false\" type=\"bool\"><Property default=\"1\" description=\"The type of message that will be logged if a SQL statement fails.\" label=\"Message type for statement errors\" maxOccurs=\"1\" minOccurs=\"0\" name=\"LogLevelForTruncateStatement\" required=\"false\" type=\"int\"><Value code=\"0\">None</Value><Value code=\"1\">Warning</Value><Value code=\"2\">Info</Value></Property></Property><Property default=\"false\" description=\"If set to Yes, the Truncate statement property specifies a file name/path containing the SQL statement. Otherwise it specifies the actual SQL statement.\" filterProperty=\"/Usage/TableAction/GenerateTruncateStatement\" filterValue=\"false\" label=\"Read truncate statement from file\" maxOccurs=\"1\" minOccurs=\"0\" name=\"ReadTruncateStatementFromFile\" required=\"false\" type=\"bool\"/><Property contexts=\"target\" default=\"\" description=\"Specifies a user-defined TRUNCATE TABLE statement.\" filterProperty=\"/Usage/TableAction/GenerateTruncateStatement\" filterValue=\"false\" label=\"Truncate statement\" maxOccurs=\"1\" minOccurs=\"0\" multiline=\"true\" name=\"TruncateStatement\" required=\"true\" type=\"string\"><Callouts><Callout callout=\"generateSQL\" calloutFilterProperty=\"/Usage/TableAction/GenerateTruncateStatement/ReadTruncateStatementFromFile\" calloutFilterValue=\"1\" calloutLabel=\"Generate statement\" calloutType=\"builder\"><CalloutArgument name=\"statementType\">TruncateTableSQL</CalloutArgument></Callout></Callouts></Property></Property></Property><Property contexts=\"source request\" description=\"Transaction properties\" inputLinkCountConstraint=\"single\" label=\"Transaction\" name=\"Transaction\" transactionModels=\"local\" type=\"category\"><Property contexts=\"source request\" default=\"2000\" description=\"Indicates the number of records (rows) in a single wave.\" label=\"Record count\" maxValue=\"999999999\" minValue=\"0\" name=\"RecordCount\" required=\"false\" type=\"int\"/><Property contexts=\"source request\" default=\"false\" description=\"If set to Yes, the connector emits an end-of-wave marker after the specified number of rows (Record count) is read from the Netezza server. If set to No, the connector will not emit end-of-wave markers.\" engines=\"ee\" label=\"Mark end of wave\" maxOccurs=\"1\" minOccurs=\"1\" name=\"MarkEndOfWave\" required=\"false\" type=\"bool\"/></Property><Property description=\"Session properties\" label=\"Session\" maxOccurs=\"1\" minOccurs=\"0\" name=\"Session\" required=\"false\" scope=\"all\" type=\"category\"><Property contexts=\"request\" default=\"2000\" description=\"Enter a number that represents the number of records to process in read and write operations on the database. Enter 0 to process all records in a single array. Enter 1 to process one record at a time.\" label=\"Array size\" maxOccurs=\"1\" maxValue=\"999999999\" minOccurs=\"0\" minValue=\"1\" name=\"ArraySize\" required=\"false\" type=\"int\"/><Property default=\"1\" description=\"Schema reconciliation represents actions that the connector takes when comparing the schema on the input link with the table schema. If an existing temporary work table is provided, the input link columns are compared to its columns. Otherwise the target table is used for comparison.\" label=\"Schema reconciliation\" maxOccurs=\"1\" minOccurs=\"0\" name=\"SchemaReconciliation\" required=\"false\" scope=\"stage\" transactionModels=\"local\" type=\"category\"><Property contexts=\"source\" default=\"1\" description=\"Action to take when an input link column does not match any columns in the table.\" label=\"Unmatched link column action\" maxOccurs=\"1\" minOccurs=\"1\" name=\"UnmatchedLinkColumnActionSource\" required=\"false\" type=\"int\"><Value code=\"1\" engines=\"ee\">Drop</Value><Value code=\"2\">Fail</Value></Property><Property contexts=\"source\" default=\"1\" description=\"Action to take upon detecting a type mismatch. The value Fail will cause the job to abort.\" label=\"Type mismatch action\" maxOccurs=\"1\" minOccurs=\"1\" name=\"TypeMismatchActionSource\" required=\"false\" type=\"int\"><Value code=\"0\">Keep</Value><Value code=\"1\" engines=\"ee\">Drop</Value><Value code=\"2\">Fail</Value></Property><Property contexts=\"source\" default=\"3\" description=\"Action to take when a table or a query column does not match any output link columns\" filterForRCP=\"false\" label=\"Unmatched table or query column action\" maxOccurs=\"1\" minOccurs=\"1\" name=\"UnmatchedTableOrQueryColumnActionSource\" required=\"false\" type=\"int\"><Value code=\"3\">Ignore</Value><Value code=\"2\">Fail</Value></Property><Property contexts=\"source\" default=\"2\" description=\"The type of message that will be logged if one or more columns unmatched or mismatched.\" label=\"Mismatch reporting action\" maxOccurs=\"1\" minOccurs=\"1\" name=\"MismatchReportingActionSource\" required=\"false\" type=\"int\"><Value code=\"0\">None</Value><Value code=\"1\">Info</Value><Value code=\"2\">Warning</Value></Property><Property contexts=\"target\" default=\"1\" description=\"Action to take when an input link column does not match any columns in the table.\" label=\"Unmatched link column action\" maxOccurs=\"1\" minOccurs=\"1\" name=\"UnmatchedLinkColumnAction\" required=\"false\" type=\"int\"><Value code=\"0\" filterProperty=\"/Usage/Session/TemporaryWorkTable\" filterValue=\"0\">Keep</Value><Value code=\"1\">Drop</Value><Value code=\"2\">Fail</Value></Property><Property contexts=\"request\" default=\"1\" description=\"Action to take when an input link column does not match any columns in the table.\" label=\"Unmatched link column action\" maxOccurs=\"1\" minOccurs=\"1\" name=\"UnmatchedLinkColumnActionRequestInputLink\" required=\"false\" type=\"int\"><Value code=\"1\">Drop</Value><Value code=\"2\">Fail</Value></Property><Property contexts=\"target request\" default=\"1\" description=\"Action to take upon detecting a type mismatch. The value Fail will cause the job to abort.\" label=\"Type mismatch action\" maxOccurs=\"1\" minOccurs=\"1\" name=\"TypeMismatchAction\" required=\"false\" type=\"int\"><Value code=\"0\">Keep</Value><Value code=\"1\">Drop</Value><Value code=\"2\">Fail</Value></Property><Property contexts=\"target\" default=\"1\" description=\"Action to take when a table column does not match any input link columns. If an existing temporary work table is provided, its columns are checked against the input link columns. Otherwise target table columns are checked\" filterProperty=\"/Usage/WriteMode\" filterValue=\"0 4 5 10\" label=\"Unmatched table column action\" maxOccurs=\"1\" minOccurs=\"1\" name=\"UnmatchedTableColumnAction\" required=\"false\" type=\"int\"><Value code=\"0\">Ignore all</Value><Value code=\"1\">Ignore nullable</Value><Value code=\"2\">Fail</Value></Property><Property contexts=\"target request\" default=\"2\" description=\"The type of message that will be logged if one or more columns unmatched or mismatched.\" label=\"Mismatch reporting action\" maxOccurs=\"1\" minOccurs=\"1\" name=\"MismatchReportingAction\" required=\"false\" type=\"int\"><Value code=\"0\">None</Value><Value code=\"1\">Info</Value><Value code=\"2\">Warning</Value></Property><Property contexts=\"request\" default=\"3\" description=\"Action to take when a table or a query column does not match any output link columns\" filterForRCP=\"false\" label=\"Unmatched table or query column action\" maxOccurs=\"1\" minOccurs=\"1\" name=\"UnmatchedTableOrQueryColumnActionRequest\" required=\"false\" type=\"int\"><Value code=\"3\">Ignore</Value><Value code=\"2\">Fail</Value></Property></Property><Property contexts=\"target\" default=\"0\" description=\"If set to Automatic, the connector will automatically create the temporary work table using an internally generated name. If set to User-defined, the connector will automatically create the temporary work table using the specified table name or create table statement.\" label=\"Temporary work table mode\" maxOccurs=\"1\" minOccurs=\"0\" name=\"TemporaryWorkTable\" required=\"false\" type=\"int\"><Filter logic=\"or\"><FilterProperty logic=\"or\" property=\"/Usage/SQL/DirectInsert\">false</FilterProperty><FilterProperty logic=\"or\" property=\"/Usage/WriteMode\">1 2 4 5 7 10</FilterProperty></Filter><Value code=\"0\">Automatic</Value><Value code=\"1\">Existing</Value><Value code=\"2\">User-defined</Value><Property description=\"The name of the temporary work table.\" filterProperty=\"/Usage/Session/TemporaryWorkTable\" filterValue=\"1 2\" label=\"Table name\" maxOccurs=\"1\" minOccurs=\"1\" name=\"TableName\" required=\"true\" type=\"string\"/><Property default=\"\" description=\"Specifies a user-defined CREATE TABLE statement.\" filterProperty=\"/Usage/Session/TemporaryWorkTable\" filterValue=\"2\" label=\"Create statement\" maxOccurs=\"1\" minOccurs=\"0\" multiline=\"true\" name=\"CreateStatement\" required=\"false\" type=\"string\"/><Property default=\"false\" description=\"If set to Yes, the temporary work table is truncated before any data is written to it.\" filterProperty=\"/Usage/Session/TemporaryWorkTable\" filterValue=\"1\" label=\"Truncate table\" maxOccurs=\"1\" minOccurs=\"1\" name=\"TruncateTable\" required=\"false\" type=\"bool\"/><Property default=\"true\" description=\"If set to Yes, the connector will drop the temporary work table.\" label=\"Drop table\" maxOccurs=\"1\" minOccurs=\"1\" name=\"DropTable\" required=\"false\" type=\"bool\"/><Property contexts=\"target\" default=\"0\" description=\"Sets the ENABLE_MERGEJOIN configuration parameter. If set to Yes, the connector will enable Netezza query planner's use of merge-join plan types. If set to No, the planner will choose one of other algorithms, including hash-join as a highly optimized one. If set to Database default, the property will not be set before query execution, using the current database setting.\" label=\"Enable use of merge-join plan type\" maxOccurs=\"1\" minOccurs=\"1\" name=\"EnableMergeJoin\" required=\"false\" type=\"int\"><Value code=\"0\">Database default</Value><Value code=\"1\">Yes</Value><Value code=\"2\">No</Value></Property></Property><Property contexts=\"source\" description=\"Unload options\" label=\"Unload options\" maxOccurs=\"1\" minOccurs=\"0\" name=\"UnloadOptions\" required=\"false\" scope=\"all\" type=\"category\"><Property description=\"Specifies the directory for the named pipe on Unix. It is ignored on Windows. If it is left blank, the connector will use the value of the environment variable TMPDIR. If TMPDIR is not defined, it will default to /tmp.\" label=\"Directory for named pipe (Unix only)\" maxOccurs=\"1\" minOccurs=\"1\" name=\"DirectoryForNamedPipe\" required=\"false\" type=\"string\"/></Property><Property contexts=\"target\" description=\"Load options\" label=\"Load options\" maxOccurs=\"1\" minOccurs=\"0\" name=\"LoadOptions\" required=\"false\" scope=\"all\" type=\"category\"><Property default=\"false\" description=\"If set to Yes, the connector will run a query that verifies the uniqueness of the primary column after the connector consumes all input link data and writes all duplicate rows into the reject table. In set to No, no check is performed.\" filterProperty=\"/Usage/WriteMode\" filterValue=\"0 4 5 10\" hidden=\"true\" label=\"Validate primary keys\" maxOccurs=\"1\" minOccurs=\"1\" name=\"ValidatePKs\" required=\"false\" type=\"bool\"><Property description=\"The name of the reject table. The table must reside in the same database as the target table.\" filterProperty=\"/Usage/Session/LoadOptions/ValidatePKs\" filterValue=\"true\" label=\"Reject table name\" maxOccurs=\"1\" minOccurs=\"1\" name=\"RejectTableName\" required=\"false\" type=\"string\"/></Property><Property contexts=\"target\" default=\"false\" description=\"If set to Yes, the connector will generate statistics. If set to No, no statistics will be generated.\" filterChildPropertiesOnValue=\"true\" label=\"Generate statistics\" maxOccurs=\"1\" minOccurs=\"1\" name=\"GenerateStatistics\" required=\"false\" type=\"bool\"><Property contexts=\"target\" default=\"1\" description=\"Choose whether to generate statistics for a table or the whole database\" label=\"Generate statistics mode\" maxOccurs=\"1\" minOccurs=\"1\" name=\"GenerateStatisticsMode\" required=\"false\" type=\"int\"><Value code=\"1\">Table</Value><Value code=\"2\">Database</Value></Property><Property callout=\"allColumns\" calloutDescription=\"Click here to obtain the list of columns\" calloutLabel=\"Select columns\" calloutType=\"enumerator\" contexts=\"target\" description=\"Select the columns to generate the statistics for. If no columns are selected (default state), all columns of the target table will be included.\" filterProperty=\"/Usage/Session/LoadOptions/GenerateStatistics/GenerateStatisticsMode\" filterValue=\"1\" label=\"Generate statistics on columns\" maxOccurs=\"999999\" minOccurs=\"1\" multiline=\"true\" name=\"GenerateStatisticsColumns\" required=\"false\" type=\"string\" xsi:type=\"asc:CalloutProperty\"/></Property><Property contexts=\"target\" default=\"1\" description=\"The number of rejected records that are logged before the job aborts.\" label=\"Maximum reject count\" maxOccurs=\"1\" maxValue=\"2147483647\" minOccurs=\"0\" minValue=\"1\" name=\"MaxRejectCount\" required=\"false\" type=\"int\"/><Property contexts=\"target\" description=\"Specifies the directory for the named pipe on Unix. It is ignored on Windows. If it is left blank, the connector will use the value of the environment variable TMPDIR. If TMPDIR is not defined, it will default to /tmp.\" label=\"Directory for named pipe (Unix only)\" maxOccurs=\"1\" minOccurs=\"1\" name=\"DirectoryForNamedPipe\" required=\"false\" type=\"string\"/><Property contexts=\"target\" description=\"Specifies the directory for the nzlog and nzbad files. If it is left blank, the connector will use the value of the environment variable TMPDIR. If TMPDIR is not defined, it will default to /tmp on Unix and to system temporary directory on Windows.\" label=\"Directory for log files\" maxOccurs=\"1\" minOccurs=\"1\" name=\"DirectoryForLogFiles\" required=\"false\" type=\"string\"/><Property contexts=\"target\" description=\"Additional options to be passed to the external table create statement.\" label=\"Other options\" maxOccurs=\"1\" minOccurs=\"1\" name=\"OtherOptions\" required=\"false\" type=\"string\"/></Property></Property><Property default=\"false\" description=\"Setting it to Yes, enables child properties for specifying Before and After SQL statements.\" filterChildPropertiesOnValue=\"true\" label=\"Before/After SQL\" maxOccurs=\"1\" minOccurs=\"0\" name=\"BeforeAfterSQL\" required=\"false\" type=\"bool\"><Property default=\"\" description=\"One or more statements to be executed before the connector starts processing any input rows. Multiple statements are separated by semi-colon. Executed once from the conductor node.\" label=\"Before SQL\" maxOccurs=\"1\" minOccurs=\"0\" multiline=\"true\" name=\"BeforeSQL\" required=\"false\" type=\"string\"><Property default=\"false\" description=\"If set to Yes, the Before SQL property specifies a file name/path containing the SQL statement. Otherwise it specifies the actual SQL statement.\" label=\"Read statement from file\" maxOccurs=\"1\" minOccurs=\"1\" name=\"ReadFromFile\" required=\"false\" type=\"bool\"/><Property default=\"true\" description=\"If set to Yes, the job will be aborted if the statement fails. If set to No, the statement errors will be ignored.\" label=\"Fail on error\" maxOccurs=\"1\" minOccurs=\"0\" name=\"FailOnError\" required=\"false\" type=\"bool\"><Property default=\"true\" description=\"If the atomic mode is yes, execute all statements in one transaction. Otherwise, execute each statement as separate transaction.\" filterProperty=\"/Usage/BeforeAfterSQL/BeforeSQL/FailOnError\" filterValue=\"true\" label=\"Atomic Mode\" maxOccurs=\"1\" minOccurs=\"1\" name=\"AtomicMode\" required=\"false\" type=\"bool\"/><Property default=\"1\" description=\"The type of message that will be logged if a SQL statement fails.\" filterProperty=\"/Usage/BeforeAfterSQL/BeforeSQL/FailOnError\" filterValue=\"false\" label=\"Message type for statement errors\" maxOccurs=\"1\" minOccurs=\"0\" name=\"LogLevelForBeforeSQL\" required=\"false\" type=\"int\"><Value code=\"0\">None</Value><Value code=\"1\">Warning</Value><Value code=\"2\">Info</Value></Property></Property></Property><Property default=\"\" description=\"One or more statements to be executed after the connector finished processing all input rows. Multiple statements are separated by semi-colon. Executed once from the conductor node.\" label=\"After SQL\" maxOccurs=\"1\" minOccurs=\"0\" multiline=\"true\" name=\"AfterSQL\" required=\"false\" type=\"string\"><Property default=\"false\" description=\"If set to Yes, the After SQL property specifies a file name/path containing the SQL statement. Otherwise it specifies the actual SQL statement.\" label=\"Read statement from file\" maxOccurs=\"1\" minOccurs=\"1\" name=\"ReadFromFile\" required=\"false\" type=\"bool\"/><Property default=\"true\" description=\"If set to Yes, the job will be aborted if the statement fails. If set to No, the statement errors will be ignored.\" label=\"Fail on error\" maxOccurs=\"1\" minOccurs=\"0\" name=\"FailOnError\" required=\"false\" type=\"bool\"><Property default=\"true\" description=\"If the atomic mode is yes, execute all statements in one transaction. Otherwise, execute each statement as separate transaction.\" filterProperty=\"/Usage/BeforeAfterSQL/AfterSQL/FailOnError\" filterValue=\"true\" label=\"Atomic Mode\" maxOccurs=\"1\" minOccurs=\"1\" name=\"AtomicMode\" required=\"false\" type=\"bool\"/><Property default=\"1\" description=\"The type of message that will be logged if a SQL statement fails.\" filterProperty=\"/Usage/BeforeAfterSQL/AfterSQL/FailOnError\" filterValue=\"false\" label=\"Message type for statement errors\" maxOccurs=\"1\" minOccurs=\"0\" name=\"LogLevelForAfterSQL\" required=\"false\" type=\"int\"><Value code=\"0\">None</Value><Value code=\"1\">Warning</Value><Value code=\"2\">Info</Value></Property></Property></Property><Property default=\"\" description=\"One or more statements to be executed before the connector starts processing any input rows Multiple statements are separated by semi-colon. Executed once in each processing node. (Parallel canvas only)\" engines=\"ee\" label=\"Before SQL (node)\" maxOccurs=\"1\" minOccurs=\"0\" multiline=\"true\" name=\"BeforeSQLNode\" required=\"false\" type=\"string\"><Property default=\"false\" description=\"If set to Yes, the Before SQL (Node) property specifies a file name/path containing the SQL statement. Otherwise it specifies the actual SQL statement.\" label=\"Read statement from file\" maxOccurs